{
  "name": "@gramola/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.gen.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff --schema public",
    "db:types": "supabase gen types typescript --local --schema public > src/types.gen.ts"
  },
  "devDependencies": {
    "@gramola/config-tsconfig": "workspace:*",
    "typescript": "^5.6.3"
  }
}
