WEB_BASE_URL=http://localhost:3000
# Must match apps/web's INGEST_SECRET exactly.
INGEST_SECRET=replace-me-with-a-32-char-or-longer-secret

# WhatsApp group id — find it by running the bot once and sending a test message
# in the group; the bot logs `from` for every incoming message.
WHATSAPP_GROUP_ID=120363XXXXXXXXXX@g.us

# Optional: YouTube Data API v3 key. Without it, paid-source posts are still
# created but won't have inline playback resolution.
# YOUTUBE_API_KEY=

# Persistent session storage. On Railway/Fly, mount a volume at this path.
SESSION_DIR=./sessions

LOG_LEVEL=info
BOOT_CUTOFF_SECONDS=300
NODE_ENV=production
