# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
NEXT_PUBLIC_SITE_NAME=Gramola

# Server-only
SUPABASE_SERVICE_ROLE_KEY=ey...
# 32+ random bytes. Generate: `openssl rand -hex 32`
INGEST_SECRET=replace-me-with-a-32-char-or-longer-secret
# Either SESSION_SECRET (single string) OR SESSION_SECRETS (JSON array for rotation)
SESSION_SECRET=replace-me-with-a-32-char-or-longer-secret
# SESSION_SECRETS=["current-secret-32-chars+","previous-secret-32-chars+"]
SITE_URL=http://localhost:3000

# Optional — enables distributed rate limiting. Falls back to in-memory when unset.
# RATE_LIMIT_UPSTASH_URL=https://YOUR.upstash.io
# RATE_LIMIT_UPSTASH_TOKEN=...
